# Aptura OS package list for live-build.
# Lines beginning with # are ignored by scripts/build-iso.sh.

# Aptura packages are injected through config/packages.chroot during build.
# Do not list them here unless you switch to a signed Aptura APT repository.

# Pull the rolling Debian kernel meta-package from trixie-backports.
linux-image-amd64/trixie-backports
live-boot
live-config
systemd-sysv
sudo
locales
keyboard-configuration
console-setup
tzdata

network-manager
wireless-tools
wpasupplicant
bluetooth
bluez
pipewire
pipewire-pulse
wireplumber
alsa-utils

# Hardware, diagnostics, and repair tools.
htop
ncdu
inxi
lshw
pciutils
usbutils
smartmontools
nvme-cli
needrestart

# KDE Plasma desktop.
# Use Debian trixie packages directly so the default desktop stack no longer
# depends on a temporary external desktop archive.
kde-plasma-desktop
plasma-workspace
sddm
systemsettings
dolphin
konsole
kate
ark
kde-spectacle
plasma-discover
xdg-desktop-portal-kde

# Temporary software center replacement
gnome-software
gnome-software-plugin-flatpak
appstream
packagekit

xwayland
file-roller
synaptic
network-manager-gnome
blueman
pavucontrol
gvfs
gvfs-backends
xdg-desktop-portal
xdg-user-dirs
xdg-user-dirs-gtk
flatpak
fwupd
power-profiles-daemon
switcheroo-control
gnome-disk-utility
baobab
deja-dup
timeshift
catfish
gufw
zenity

firefox-esr
curl
wget
git
vim-tiny
less
gnupg
ca-certificates
apt-transport-https
unattended-upgrades
ufw
apparmor
apparmor-utils
fonts-noto-color-emoji

cups
cups-browsed
ipp-usb
sane-airscan
system-config-printer
simple-scan

calamares
calamares-settings-debian
parted
gparted
dosfstools
mtools
cryptsetup
cryptsetup-initramfs
grub-common
grub2-common
grub-efi-amd64-bin
grub-pc-bin
efibootmgr
os-prober
