# Aptura OS package list for live-build.
# Lines beginning with # are ignored by scripts/build-iso.sh.

# Aptura packages are injected through config/packages.chroot during build.
# Do not list them here unless you switch to a signed Aptura APT repository.

# Pull the rolling Debian kernel meta-package from trixie-backports.
linux-image-amd64/trixie-backports
live-boot
live-config
systemd-sysv
sudo
locales
keyboard-configuration
console-setup
tzdata

network-manager
wireless-tools
wpasupplicant
bluetooth
bluez
pipewire
pipewire-pulse
wireplumber
alsa-utils

# Hardware, diagnostics, and repair tools.
htop
ncdu
inxi
lshw
pciutils
usbutils
smartmontools
nvme-cli
needrestart

# COSMIC Desktop from System76.
# Debian trixie does not currently ship this as a stable desktop set.
# The build resolves these through the pinned Debian_13 COSMIC archive in
# config/live-build/config/archives until Aptura publishes its own mirror.
cosmic-session
cosmic-greeter
cosmic-greeter-daemon
cosmic-comp
cosmic-panel
cosmic-applets
cosmic-app-library
cosmic-icons
cosmic-launcher
cosmic-bg
cosmic-idle
cosmic-notifications
cosmic-osd
cosmic-randr
cosmic-screenshot
cosmic-settings
cosmic-settings-daemon
cosmic-files
cosmic-term
cosmic-edit
cosmic-player
# cosmic-store requires appstream-data-pop, which is not available in the
# configured external COSMIC repository. Disable until the dependency can
# be provided by the build sources.
# cosmic-store
cosmic-wallpapers
cosmic-workspaces
xdg-desktop-portal-cosmic

# Temporary software center replacement
gnome-software
gnome-software-plugin-flatpak
appstream
packagekit

greetd
xwayland
file-roller
synaptic
network-manager-gnome
blueman
pavucontrol
gvfs
gvfs-backends
xdg-desktop-portal
xdg-user-dirs
xdg-user-dirs-gtk
flatpak
fwupd
power-profiles-daemon
switcheroo-control
gnome-disk-utility
baobab
deja-dup
timeshift
catfish
gufw
zenity

firefox-esr
curl
wget
git
vim-tiny
less
gnupg
ca-certificates
apt-transport-https
unattended-upgrades
ufw
apparmor
apparmor-utils
fonts-noto-color-emoji

cups
cups-browsed
ipp-usb
sane-airscan
system-config-printer
simple-scan

calamares
calamares-settings-debian
parted
gparted
dosfstools
mtools
grub-common
grub2-common
grub-pc
grub-efi-amd64-bin
grub-efi-amd64
grub-pc-bin
efibootmgr
os-prober
