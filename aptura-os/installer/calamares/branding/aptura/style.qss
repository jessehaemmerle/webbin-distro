QWidget {
  font-family: Sans, Arial, Helvetica, sans-serif;
  color: #101318;
  background: #c0c0c0;
}

#sidebarAppName {
  color: #000000;
  font-weight: 700;
}

#sidebarMenuApp {
  background: #c0c0c0;
  border-right: 3px solid #000000;
}

#sidebarMenuApp QListView::item:selected {
  color: #ffffff;
  background: #000080;
}

QPushButton {
  background: #c8c6bc;
  border-top: 2px solid #f4f0df;
  border-left: 2px solid #f4f0df;
  border-right: 2px solid #686a72;
  border-bottom: 2px solid #686a72;
  padding: 6px 14px;
}

QPushButton:pressed {
  background: #b6b2a8;
  border-top: 2px solid #686a72;
  border-left: 2px solid #686a72;
  border-right: 2px solid #f4f0df;
  border-bottom: 2px solid #f4f0df;
}

QLineEdit,
QComboBox,
QTextEdit,
QPlainTextEdit {
  background: #f4f0df;
  color: #101318;
  border-top: 2px solid #686a72;
  border-left: 2px solid #686a72;
  border-right: 2px solid #ffffff;
  border-bottom: 2px solid #ffffff;
  padding: 4px;
}

QProgressBar {
  border: 2px solid #05070a;
  background: #7b7c82;
  text-align: center;
}

QProgressBar::chunk {
  background: #000080;
}

QTabBar::tab {
  background: #aaa79e;
  color: #101318;
  border-top: 2px solid #f4f0df;
  border-left: 2px solid #f4f0df;
  border-right: 2px solid #686a72;
  padding: 6px 12px;
}

QTabBar::tab:selected {
  background: #c8c6bc;
}
