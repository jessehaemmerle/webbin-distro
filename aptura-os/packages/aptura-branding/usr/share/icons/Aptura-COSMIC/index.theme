[Icon Theme]
Name=Aptura COSMIC
Comment=Retro COSMIC icons for Aptura OS
Inherits=hicolor,Adwaita
Directories=scalable/apps,scalable/places,scalable/devices

[scalable/apps]
Size=48
Type=Scalable
MinSize=16
MaxSize=256
Context=Applications

[scalable/places]
Size=48
Type=Scalable
MinSize=16
MaxSize=256
Context=Places

[scalable/devices]
Size=48
Type=Scalable
MinSize=16
MaxSize=256
Context=Devices
