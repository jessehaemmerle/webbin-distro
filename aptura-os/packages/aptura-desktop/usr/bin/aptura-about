#!/usr/bin/env bash
set -euo pipefail

title="About Aptura OS"
message="Aptura OS 0.1.4 Adeline Shell

A Debian-compatible desktop distribution with Aptura Shell, Wayland defaults, practical tooling, and a Plasma fallback session.

Edition: Adeline Shell
Base: Debian trixie
Kernel channel: trixie-backports"

if command -v zenity >/dev/null 2>&1; then
  zenity --info \
    --title="${title}" \
    --window-icon=distributor-logo-aptura \
    --width=440 \
    --text="${message}"
else
  printf '%s\n\n%s\n' "${title}" "${message}"
fi
