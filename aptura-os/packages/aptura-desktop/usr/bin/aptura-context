#!/usr/bin/env bash
set -u

have() {
  command -v "$1" >/dev/null 2>&1
}

line() {
  printf '%-24s %s\n' "$1" "$2"
}

section() {
  printf '\n%s\n' "$1"
  printf '%s\n' '----------------'
}

record_journey() {
  if have aptura-journey; then
    aptura-journey record context "$*" >/dev/null 2>&1 || true
  fi
}

is_live_session() {
  if [[ -d /run/live/medium || -d /lib/live/mount/medium ]]; then
    return 0
  fi
  [[ -r /proc/cmdline ]] && grep -Eq 'boot=live|findiso=|live-media=' /proc/cmdline
}

live_state() {
  if is_live_session; then
    printf 'live session'
  else
    printf 'installed or build host'
  fi
}

virt_state() {
  if have systemd-detect-virt; then
    local virt
    virt="$(systemd-detect-virt 2>/dev/null || true)"
    if [[ -n "${virt}" && "${virt}" != "none" ]]; then
      printf '%s' "${virt}"
      return
    fi
  fi

  if [[ -r /sys/class/dmi/id/product_name ]] && grep -Eiq 'virtual|qemu|kvm|vmware|virtualbox|hyper-v' /sys/class/dmi/id/product_name; then
    tr -d '\n' < /sys/class/dmi/id/product_name
    return
  fi

  printf 'not detected'
}

chassis_state() {
  if compgen -G '/sys/class/power_supply/BAT*' >/dev/null 2>&1; then
    printf 'laptop or portable'
  else
    printf 'desktop or VM'
  fi
}

battery_state() {
  local bat cap status
  for bat in /sys/class/power_supply/BAT*; do
    [[ -r "${bat}/capacity" ]] || continue
    cap="$(cat "${bat}/capacity" 2>/dev/null || printf '?')"
    status="$(cat "${bat}/status" 2>/dev/null || printf 'unknown')"
    printf '%s%%, %s' "${cap}" "${status}"
    return
  done
  printf 'not present'
}

network_state() {
  if have ip && ip route get 1.1.1.1 >/dev/null 2>&1; then
    printf 'route available'
  else
    printf 'no default route detected'
  fi
}

dns_state() {
  if have getent && getent hosts debian.org >/dev/null 2>&1; then
    printf 'resolves names'
  else
    printf 'not confirmed'
  fi
}

boot_mode() {
  if [[ -d /sys/firmware/efi ]]; then
    printf 'UEFI'
  else
    printf 'BIOS/legacy'
  fi
}

disk_pressure() {
  if have df; then
    df -h / 2>/dev/null | awk 'NR == 2 { printf "%s used, %s free", $5, $4 }'
  else
    printf 'unknown'
  fi
}

session_name() {
  printf '%s' "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"
}

suggestions() {
  section "Suggested Next Moves"

  if is_live_session; then
    printf '* Run aptura-live-bridge before installing.\n'
  fi

  if [[ "$(network_state)" == no* ]]; then
    printf '* Connect networking before updates, firmware checks, or installation.\n'
  fi

  if compgen -G '/sys/class/power_supply/BAT*' >/dev/null 2>&1; then
    printf '* Use aptura-shift travel or focus when battery matters.\n'
  fi

  printf '* Run aptura-aftercare after major updates.\n'
  printf '* Run aptura-journey to review local Aptura events.\n'
}

usage() {
  cat <<'EOF'
Usage: aptura-context

Detects the local Aptura session context and prints practical next moves.
EOF
}

main() {
  case "${1:-}" in
    -h|--help)
      usage
      return 0
      ;;
  esac

  printf 'Aptura Context\n'
  printf '===============\n'
  line "System state" "$(live_state)"
  line "Virtualization" "$(virt_state)"
  line "Chassis" "$(chassis_state)"
  line "Battery" "$(battery_state)"
  line "Network" "$(network_state)"
  line "DNS" "$(dns_state)"
  line "Boot mode" "$(boot_mode)"
  line "Session" "$(session_name)"
  line "Root storage" "$(disk_pressure)"

  suggestions
  record_journey "checked $(live_state), $(chassis_state), $(boot_mode)"
}

main "$@"
