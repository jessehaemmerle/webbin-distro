#!/usr/bin/env bash
set -euo pipefail

MODE="${1:---dashboard}"
HTML="/usr/share/aptura-flow/index.html"
APP_URI="file://${HTML}"

case "${MODE}" in
  --settings)
    APP_URI="${APP_URI}#settings"
    ;;
  --updates)
    APP_URI="${APP_URI}#updates"
    ;;
  --welcome)
    APP_URI="${APP_URI}#welcome"
    ;;
  *)
    APP_URI="${APP_URI}#dashboard"
    ;;
esac

if [[ ! -f "${HTML}" ]]; then
  printf 'Aptura Flow system app is missing %s\n' "${HTML}" >&2
  exit 1
fi

if command -v gio >/dev/null 2>&1; then
  exec gio open "${APP_URI}"
fi

if command -v xdg-open >/dev/null 2>&1; then
  exec xdg-open "${APP_URI}"
fi

if command -v sensible-browser >/dev/null 2>&1; then
  exec sensible-browser "${APP_URI}"
fi

printf 'Aptura Flow is installed at %s but no desktop opener was found.\n' "${HTML}" >&2
exit 1
