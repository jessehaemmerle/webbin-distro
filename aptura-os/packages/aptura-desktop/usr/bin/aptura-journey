#!/usr/bin/env bash
set -euo pipefail

state_root() {
  if [[ -n "${XDG_STATE_HOME:-}" ]]; then
    printf '%s' "${XDG_STATE_HOME}"
  elif [[ -n "${HOME:-}" ]]; then
    printf '%s/.local/state' "${HOME}"
  else
    printf '/tmp'
  fi
}

journey_dir() {
  printf '%s/aptura' "$(state_root)"
}

journey_log() {
  printf '%s' "${APTURA_JOURNEY_LOG:-$(journey_dir)/journey.log}"
}

usage() {
  cat <<'EOF'
Usage: aptura-journey [show|record|path|clear] [event] [message...]

Local-only system journey log for Aptura OS.

Commands:
  show              Show recent journey entries (default)
  record EVENT MSG  Append a local event
  path              Print the log path
  clear             Remove the local journey log
EOF
}

timestamp() {
  date -Is 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z'
}

ensure_log_dir() {
  mkdir -p "$(dirname "$(journey_log)")"
}

record_event() {
  local event="${1:-note}"
  shift || true
  local message="${*:-}"

  ensure_log_dir
  printf '%s\t%s\t%s\n' "$(timestamp)" "${event}" "${message}" >> "$(journey_log)"
}

show_entries() {
  local log
  log="$(journey_log)"

  printf 'Aptura Journey\n'
  printf '===============\n'
  printf 'Log: %s\n\n' "${log}"

  if [[ ! -s "${log}" ]]; then
    printf 'No local journey entries yet.\n'
    printf 'Run Aptura Context, Shift, Aftercare, or Live Bridge to start one.\n'
    return 0
  fi

  tail -n "${APTURA_JOURNEY_LINES:-30}" "${log}" | awk -F '\t' '{
    printf "%s  %-18s %s\n", $1, $2, $3
  }'
}

main() {
  case "${1:-show}" in
    -h|--help)
      usage
      ;;
    show)
      show_entries
      ;;
    record)
      shift || true
      record_event "$@"
      ;;
    path)
      journey_log
      printf '\n'
      ;;
    clear)
      rm -f "$(journey_log)"
      printf 'Aptura Journey cleared.\n'
      ;;
    *)
      usage >&2
      return 1
      ;;
  esac
}

main "$@"
