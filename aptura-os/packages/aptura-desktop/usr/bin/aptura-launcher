#!/usr/bin/env bash
set -euo pipefail

if [[ -r /usr/share/aptura-shell/branding.sh ]]; then
  # shellcheck source=/dev/null
  source /usr/share/aptura-shell/branding.sh
fi

if ! command -v wofi >/dev/null 2>&1; then
  printf '%s launcher needs wofi, but wofi is not installed.\n' "${SHORT_NAME:-Aptura}" >&2
  exit 127
fi

exec wofi \
  --show drun \
  --allow-images \
  --insensitive \
  --prompt "${PANEL_TITLE:-${SHORT_NAME:-Aptura}}" \
  --conf /usr/share/aptura-shell/wofi/config \
  --style /usr/share/aptura-shell/wofi/style.css
