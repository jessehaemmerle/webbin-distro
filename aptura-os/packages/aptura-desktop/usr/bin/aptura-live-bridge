#!/usr/bin/env bash
set -euo pipefail

have() {
  command -v "$1" >/dev/null 2>&1
}

line() {
  printf '%-28s %s\n' "$1" "$2"
}

section() {
  printf '\n%s\n' "$1"
  printf '%s\n' '----------------'
}

record_journey() {
  if have aptura-journey; then
    aptura-journey record live-bridge "$*" >/dev/null 2>&1 || true
  fi
}

is_live_session() {
  if [[ -d /run/live/medium || -d /lib/live/mount/medium ]]; then
    return 0
  fi
  [[ -r /proc/cmdline ]] && grep -Eq 'boot=live|findiso=|live-media=' /proc/cmdline
}

live_state() {
  if is_live_session; then
    printf 'live session detected'
  else
    printf 'not a live session'
  fi
}

boot_mode() {
  if [[ -d /sys/firmware/efi ]]; then
    printf 'UEFI'
  else
    printf 'BIOS/legacy'
  fi
}

network_state() {
  if have ip && ip route get 1.1.1.1 >/dev/null 2>&1; then
    printf 'ready'
  else
    printf 'not confirmed'
  fi
}

memory_state() {
  if have free; then
    free -h | awk '/^Mem:/ { printf "%s total, %s available", $2, $7 }'
  else
    printf 'unknown'
  fi
}

installer_state() {
  if have calamares; then
    printf 'available'
  else
    printf 'missing'
  fi
}

disk_state() {
  if have lsblk; then
    lsblk -dn -o NAME,SIZE,TYPE 2>/dev/null | awk '$3 == "disk" { printf "%s:%s ", $1, $2 } END { if (NR == 0) printf "none detected" }'
  else
    printf 'lsblk unavailable'
  fi
}

render_report() {
  printf 'Aptura Live Bridge\n'
  printf '===================\n'
  line "Live state" "$(live_state)"
  line "Boot mode" "$(boot_mode)"
  line "Network" "$(network_state)"
  line "Memory" "$(memory_state)"
  line "Installer" "$(installer_state)"
  line "Install disks" "$(disk_state)"

  section "Live Session Notes"
  printf '* Files stored only in the live user home are temporary until you install or copy them elsewhere.\n'
  printf '* Installer choices are destructive when whole-disk partitioning is selected.\n'
  printf '* UEFI systems should have an EFI System Partition mounted during installation.\n'
  printf '* Run Aptura Context if hardware, battery, or network state changes.\n'
}

write_report() {
  local base="${1:-${HOME:-/tmp}}"
  local stamp output
  stamp="$(date '+%Y%m%d-%H%M%S')"
  output="${base}/aptura-live-readiness-${stamp}.txt"

  mkdir -p "${base}"
  render_report > "${output}"
  printf '%s\n' "${output}"
  record_journey "wrote report ${output}"
}

usage() {
  cat <<'EOF'
Usage: aptura-live-bridge [--report [directory]]

Explains the live-session handoff and checks install readiness. Use --report to
write a local readiness note.
EOF
}

main() {
  case "${1:-}" in
    -h|--help)
      usage
      return 0
      ;;
    --report)
      shift || true
      write_report "${1:-${HOME:-/tmp}}"
      return 0
      ;;
  esac

  render_report
  record_journey "$(live_state), installer=$(installer_state), network=$(network_state)"
}

main "$@"
