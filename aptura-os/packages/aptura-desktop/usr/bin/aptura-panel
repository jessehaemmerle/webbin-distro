#!/usr/bin/env bash
set -euo pipefail

if [[ -r /usr/share/aptura-shell/branding.sh ]]; then
  # shellcheck source=/dev/null
  source /usr/share/aptura-shell/branding.sh
fi

config_template="/usr/share/aptura-shell/waybar/config.jsonc"
style="/usr/share/aptura-shell/waybar/style.css"

if ! command -v waybar >/dev/null 2>&1; then
  printf '%s panel needs waybar, but waybar is not installed.\n' "${SHORT_NAME:-Aptura}" >&2
  exit 127
fi

json_escape() {
  local value="${1-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "${value}"
}

runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
config="${runtime_dir}/aptura-waybar-${UID:-0}.jsonc"
panel_title="$(json_escape "${PANEL_TITLE:-Aptura}")"
panel_title="${panel_title//&/\\&}"
panel_title="${panel_title//|/\\|}"
sed "s|@BRAND_PANEL_TITLE@|${panel_title}|g" "${config_template}" > "${config}"

exec waybar --config "${config}" --style "${style}"
