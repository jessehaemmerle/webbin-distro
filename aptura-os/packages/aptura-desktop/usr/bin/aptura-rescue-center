#!/usr/bin/env bash
set -u

have() {
  command -v "$1" >/dev/null 2>&1
}

section() {
  printf '\n%s\n' "$1"
  printf '%s\n' '----------------'
}

line() {
  printf '%-24s %s\n' "$1" "$2"
}

boot_mode() {
  if [[ -d /sys/firmware/efi ]]; then
    printf 'UEFI'
  else
    printf 'BIOS/legacy'
  fi
}

mount_source() {
  local path="$1"
  if have findmnt; then
    findmnt -no SOURCE "${path}" 2>/dev/null || printf unknown
  else
    printf 'findmnt unavailable'
  fi
}

mount_target() {
  local path="$1"
  if have findmnt; then
    findmnt -no TARGET "${path}" 2>/dev/null || printf no
  else
    printf 'findmnt unavailable'
  fi
}

main() {
  case "${1:-}" in
    -h|--help)
      printf 'Usage: aptura-rescue-center\n'
      printf 'Prints a boot and installer recovery checklist for live and installed systems.\n'
      return 0
      ;;
  esac

  printf 'Aptura Rescue Center\n'
  printf '====================\n'
  line "Boot mode" "$(boot_mode)"
  line "Root mount" "$(mount_source /)"
  line "EFI mounted" "$(mount_target /boot/efi)"

  section "Disks"
  if have lsblk; then
    lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL,PARTFLAGS,MOUNTPOINTS
  else
    printf 'lsblk not available\n'
  fi

  section "EFI Entries"
  if [[ -d /sys/firmware/efi ]] && have efibootmgr; then
    efibootmgr -v 2>/dev/null || printf 'Unable to read EFI boot entries\n'
  else
    printf 'Not running in UEFI mode or efibootmgr unavailable\n'
  fi

  section "GRUB Checks"
  line "grub-install" "$(have grub-install && printf available || printf missing)"
  line "grub-mkconfig" "$(have grub-mkconfig && printf available || printf missing)"
  line "grub-probe" "$(have grub-probe && printf available || printf missing)"

  section "Installer Logs"
  for log in /var/log/calamares.log /root/.cache/calamares/session.log; do
    if [[ -r "${log}" ]]; then
      printf '%s\n' "${log}"
      tail -n 30 "${log}" 2>/dev/null
    fi
  done

  section "Repair Hints"
  printf 'UEFI installs need an EFI System Partition mounted at /boot/efi.\n'
  printf 'BIOS installs on GPT need a bios_grub partition, or use an msdos partition table.\n'
  printf 'For Debian GRUB EFI, Aptura keeps the EFI bootloader ID as debian.\n'
}

main "$@"
