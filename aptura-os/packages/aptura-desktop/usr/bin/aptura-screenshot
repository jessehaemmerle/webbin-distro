#!/usr/bin/env bash
set -euo pipefail

if [[ -r /usr/share/aptura-shell/branding.sh ]]; then
  # shellcheck source=/dev/null
  source /usr/share/aptura-shell/branding.sh
fi

have() {
  command -v "$1" >/dev/null 2>&1
}

if ! have grim; then
  printf '%s screenshot needs grim, but grim is not installed.\n' "${SHORT_NAME:-Aptura}" >&2
  exit 127
fi

picture_dir="${HOME:-/tmp}/Pictures"
if have xdg-user-dir; then
  picture_dir="$(xdg-user-dir PICTURES 2>/dev/null || printf '%s' "${picture_dir}")"
fi

target_dir="${picture_dir}/Screenshots"
mkdir -p "${target_dir}"

file="${target_dir}/aptura-$(date +%Y%m%d-%H%M%S).png"

case "${1:---screen}" in
  --screen)
    grim "${file}"
    ;;
  --region)
    if ! have slurp; then
      printf 'Region screenshots need slurp, but slurp is not installed.\n' >&2
      exit 127
    fi
    geometry="$(slurp)"
    [[ -n "${geometry}" ]] || exit 0
    grim -g "${geometry}" "${file}"
    ;;
  *)
    printf 'Usage: aptura-screenshot [--screen|--region]\n' >&2
    exit 2
    ;;
esac

if have wl-copy; then
  wl-copy --type image/png < "${file}" || true
fi

if have notify-send; then
  notify-send -a "${SHELL_SESSION_NAME:-Aptura Shell}" "Screenshot saved" "${file}"
fi

printf '%s\n' "${file}"
