#!/usr/bin/env bash
set -euo pipefail

have() {
  command -v "$1" >/dev/null 2>&1
}

redact() {
  sed -E \
    -e 's/([0-9]{1,3}\.){3}[0-9]{1,3}/<ipv4>/g' \
    -e 's/([[:xdigit:]]{1,4}:){2,}[[:xdigit:]:]{1,}/<ipv6>/g' \
    -e 's/[[:alnum:]_.%+-]+@[[:alnum:].-]+\.[[:alpha:]]{2,}/<email>/g'
}

capture() {
  local output="$1"
  shift
  {
    printf '$ %s\n\n' "$*"
    "$@" 2>&1 || true
  } | redact > "${output}"
}

main() {
  case "${1:-}" in
    -h|--help)
      printf 'Usage: aptura-support-bundle [output-directory]\n'
      printf 'Creates a redacted diagnostics archive for bug reports.\n'
      return 0
      ;;
  esac

  local base="${1:-${HOME:-/tmp}}"
  local stamp work archive
  stamp="$(date '+%Y%m%d-%H%M%S')"
  work="${base}/aptura-support-${stamp}"
  archive="${work}.tar.gz"

  mkdir -p "${work}"
  capture "${work}/os-release.txt" cat /etc/os-release
  capture "${work}/kernel.txt" uname -a
  have inxi && capture "${work}/hardware.txt" inxi -Fxz
  have lsblk && capture "${work}/disks.txt" lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL,PARTFLAGS,MOUNTPOINTS
  have systemctl && capture "${work}/failed-units.txt" systemctl --failed --no-pager
  have journalctl && capture "${work}/boot-errors.txt" journalctl -b -p warning..alert --no-pager -n 300
  have apt && capture "${work}/apt-policy.txt" apt-cache policy
  aptura-system-check > "${work}/aptura-system-check.txt" 2>&1 || true

  tar -C "${base}" -czf "${archive}" "$(basename "${work}")"
  printf '%s\n' "${archive}"
}

main "$@"
