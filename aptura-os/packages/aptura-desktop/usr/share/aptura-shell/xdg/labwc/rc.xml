<?xml version="1.0"?>
<labwc_config>
  <theme>
    <name>Aptura-Shell</name>
    <dropShadows>yes</dropShadows>
    <keepBorder>yes</keepBorder>
    <font place="ActiveWindow">
      <name>Noto Sans</name>
      <size>10</size>
    </font>
    <font place="InactiveWindow">
      <name>Noto Sans</name>
      <size>10</size>
    </font>
    <font place="MenuHeader">
      <name>Noto Sans</name>
      <size>10</size>
    </font>
    <font place="MenuItem">
      <name>Noto Sans</name>
      <size>10</size>
    </font>
  </theme>

  <placement>
    <policy>automatic</policy>
  </placement>

  <desktops number="4">
    <names>
      <name>Main</name>
      <name>Code</name>
      <name>Create</name>
      <name>Focus</name>
    </names>
  </desktops>

  <windowSwitcher>
    <allWorkspaces>yes</allWorkspaces>
  </windowSwitcher>

  <keyboard>
    <default />
    <keybind key="Super_L" onRelease="yes">
      <action name="Execute" command="aptura-launcher" />
    </keybind>
    <keybind key="W-Space">
      <action name="Execute" command="aptura-launcher" />
    </keybind>
    <keybind key="W-Return">
      <action name="Execute" command="aptura-control terminal" />
    </keybind>
    <keybind key="W-e">
      <action name="Execute" command="dolphin" />
    </keybind>
    <keybind key="W-b">
      <action name="Execute" command="firefox-esr" />
    </keybind>
    <keybind key="W-s">
      <action name="Execute" command="systemsettings" />
    </keybind>
    <keybind key="W-S-q">
      <action name="Execute" command="aptura-control power" />
    </keybind>
    <keybind key="Print">
      <action name="Execute" command="aptura-screenshot --screen" />
    </keybind>
    <keybind key="W-Print">
      <action name="Execute" command="aptura-screenshot --region" />
    </keybind>
    <keybind key="W-l">
      <action name="Execute" command="aptura-control lock" />
    </keybind>
    <keybind key="W-q">
      <action name="Close" />
    </keybind>
    <keybind key="W-f">
      <action name="ToggleFullscreen" />
    </keybind>
    <keybind key="W-Up">
      <action name="ToggleMaximize" direction="both" />
    </keybind>
    <keybind key="W-Down">
      <action name="Iconify" />
    </keybind>
    <keybind key="W-Left">
      <action name="MoveToEdge" direction="left" snapWindows="yes" />
    </keybind>
    <keybind key="W-Right">
      <action name="MoveToEdge" direction="right" snapWindows="yes" />
    </keybind>
    <keybind key="W-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="W-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="W-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="W-4">
      <action name="GoToDesktop" to="4" />
    </keybind>
    <keybind key="W-S-1">
      <action name="SendToDesktop" to="1" follow="yes" />
    </keybind>
    <keybind key="W-S-2">
      <action name="SendToDesktop" to="2" follow="yes" />
    </keybind>
    <keybind key="W-S-3">
      <action name="SendToDesktop" to="3" follow="yes" />
    </keybind>
    <keybind key="W-S-4">
      <action name="SendToDesktop" to="4" follow="yes" />
    </keybind>
  </keyboard>

  <mouse>
    <default />
    <context name="Root">
      <mousebind button="Left" action="Press">
        <action name="Unfocus" />
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="root-menu" />
      </mousebind>
    </context>
    <context name="All">
      <mousebind direction="W-Up" action="Scroll">
        <action name="GoToDesktop" to="left" />
      </mousebind>
      <mousebind direction="W-Down" action="Scroll">
        <action name="GoToDesktop" to="right" />
      </mousebind>
    </context>
  </mouse>
</labwc_config>
