# Aptura OS build configuration (Ubuntu-based).
# Tracked defaults. For local, untracked overrides create
# config/distro.local.env and/or config/branding.local.env.

# --- Identity ---------------------------------------------------------------
DISTRO_ID="aptura"
DISTRO_NAME="Aptura OS"
DISTRO_PRETTY_NAME="Aptura OS 0.1.0 Aurora"
DISTRO_VERSION="0.1.0"
DISTRO_CODENAME="aurora"
DISTRO_HOME_URL="https://aptura.example"
DISTRO_SUPPORT_URL="https://aptura.example/support"
DESKTOP_NAME="Aptura Shell"

# --- Regional defaults (German / Austria) -----------------------------------
# These seed the live session and Calamares pre-selection. Users can change all
# of them in the installer.
DEFAULT_LOCALE="de_AT.UTF-8"
DEFAULT_LANGUAGE="de_AT:de"
SECONDARY_LOCALE="en_US.UTF-8"
DEFAULT_KEYBOARD_LAYOUT="de"
DEFAULT_KEYBOARD_VARIANT="nodeadkeys"
DEFAULT_KEYBOARD_MODEL="pc105"
DEFAULT_TIMEZONE="Europe/Vienna"

# --- Base distribution (Ubuntu LTS) -----------------------------------------
# Default base is Ubuntu 24.04 LTS (noble). The latest LTS suite can be set
# here once confirmed available (e.g. a future 26.04 LTS codename).
BASE_FAMILY="ubuntu"
BASE_DISTRIBUTION="ubuntu"
BASE_SUITE="noble"
APT_COMPONENTS="main restricted universe multiverse"
ARCH="amd64"

# Ubuntu archive mirrors. Security uses the same host on Ubuntu.
MIRROR_BOOTSTRAP="http://archive.ubuntu.com/ubuntu"
MIRROR_BINARY="http://archive.ubuntu.com/ubuntu"
MIRROR_SECURITY="http://security.ubuntu.com/ubuntu"

# --- Custom kernel ----------------------------------------------------------
# Build a mainline kernel as a local .deb with Aptura branding.
# NOTE: As of early 2026 there is no "Linux 7" release; the newest series is
# 6.x. Set KERNEL_VERSION to the newest mainline you want to ship. When 7.0
# is released, bump these two values and the existing build path keeps working.
BUILD_CUSTOM_KERNEL="true"
KERNEL_VERSION="6.12.30"
KERNEL_MAJOR_SERIES="6.x"
KERNEL_LOCALVERSION="-aptura"
KERNEL_SOURCE_BASE="https://cdn.kernel.org/pub/linux/kernel"
# Build-host kernel signing is reserved for future use; the supported Secure
# Boot path is the per-machine MOK in the aptura-secureboot package.
SIGN_KERNEL="false"

# --- ISO --------------------------------------------------------------------
ISO_VOLUME_ID="APTURA_OS"
ISO_LABEL="Aptura OS Aurora Live"
ISO_NAME="aptura-os-${DISTRO_VERSION}-${DISTRO_CODENAME}-${ARCH}.iso"

# --- Build layout -----------------------------------------------------------
BUILD_DIR="build"
DIST_DIR="dist"
LOG_DIR="build/logs"
KERNEL_OUTPUT_DIR="build/kernel"
PACKAGE_OUTPUT_DIR="build/packages"
LOCAL_REPO_DIR="build/localrepo"
LIVE_BUILD_WORKDIR="build/live-build"

# --- Repository signing -----------------------------------------------------
SIGN_REPO="false"
REPO_GPG_KEY_ID=""
APTURA_REPO_ORIGIN="Aptura OS"
APTURA_REPO_LABEL="Aptura Local"

# --- Feature toggles --------------------------------------------------------
ENABLE_CALAMARES="true"
ENABLE_FLATPAK="true"
ENABLE_UNATTENDED_UPGRADES="true"
ENABLE_SECURE_BOOT_PLACEHOLDER="true"
PREFER_FLATPAK_OVER_SNAP="true"

SUPPORTED_ARCHITECTURES="amd64"
