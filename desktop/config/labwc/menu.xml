<?xml version="1.0"?>
<!-- Aptura Shell right-click root menu. -->
<openbox_menu>
  <menu id="root-menu" label="Aptura">
    <item label="Application launcher"><action name="Execute"><command>wofi --show drun</command></action></item>
    <item label="Terminal"><action name="Execute"><command>foot</command></action></item>
    <item label="Files"><action name="Execute"><command>nautilus</command></action></item>
    <item label="Web browser"><action name="Execute"><command>firefox</command></action></item>
    <item label="Software"><action name="Execute"><command>gnome-software</command></action></item>
    <item label="Settings"><action name="Execute"><command>gnome-control-center</command></action></item>
    <separator/>
    <item label="Lock"><action name="Execute"><command>swaylock -f</command></action></item>
    <item label="Power menu"><action name="Execute"><command>aptura-power-menu</command></action></item>
    <separator/>
    <item label="Reconfigure"><action name="Reconfigure"/></item>
    <item label="Exit session"><action name="Exit"/></item>
  </menu>
</openbox_menu>
