/* Aptura OS Calamares stylesheet */
#mainApp {
    background-color: #12142b;
    color: #eef1ff;
}

QPushButton {
    background-color: #00d9c0;
    color: #12142b;
    border: none;
    border-radius: 6px;
    padding: 6px 16px;
    font-weight: 600;
}
QPushButton:hover   { background-color: #7a4dff; color: #eef1ff; }
QPushButton:disabled{ background-color: #2a2d52; color: #8a8db0; }

QLabel { color: #eef1ff; }
