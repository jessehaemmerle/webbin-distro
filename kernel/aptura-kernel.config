## Aptura OS kernel config overrides.
## Layered on top of the host/Ubuntu config by kernel/build-kernel.sh.
## Lines are standard Kconfig assignments. Keep this conservative: these are
## desktop-workstation oriented defaults, not a from-scratch config.

## --- Branding -------------------------------------------------------------
## uname -r ends in -aptura (also forced via LOCALVERSION in build-kernel.sh).
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_LOCALVERSION="-aptura"

## --- Desktop responsiveness ----------------------------------------------
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_RCU_EXPERT=y

## --- Scheduling / desktop interactivity ----------------------------------
CONFIG_CGROUPS=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_SCHED_AUTOGROUP=y

## --- Filesystems commonly used on desktops -------------------------------
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=m
CONFIG_F2FS_FS=m
CONFIG_FANOTIFY=y

## --- Security (AppArmor is the Ubuntu/Aptura default LSM) -----------------
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_LSM="landlock,lockdown,yama,integrity,apparmor"

## --- Sane module / boot defaults -----------------------------------------
CONFIG_MODULE_COMPRESS_ZSTD=y
CONFIG_KERNEL_ZSTD=y

## --- Optional: tag the build (visible in dmesg/version banner) ------------
## Append your own marker if desired by setting CONFIG_BUILD_SALT.
