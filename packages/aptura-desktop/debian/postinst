#!/bin/sh
# Make the aptura-* binaries executable and set SDDM as the default DM.
set -e

case "$1" in
  configure)
    for b in aptura-session aptura-screenshot aptura-power-menu; do
      [ -f "/usr/bin/${b}" ] && chmod 0755 "/usr/bin/${b}"
    done
    # Prefer the Wayland greeter; SDDM reads the Aptura theme from settings.
    if [ -x /usr/sbin/update-alternatives ] && [ -e /usr/bin/sddm ]; then
      echo "/usr/bin/sddm" > /etc/X11/default-display-manager 2>/dev/null || true
    fi
    ;;
esac

#DEBHELPER#
exit 0
